      <aliases enabled='yes' />
      <column caption='Revenue' datatype='real' name='[Calculation_5712874514472960]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Quantity Ordered] * [Price Each]' />
      </column>
      <column caption='Month Year' datatype='datetime' name='[Calculation_5712874514591745]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [Order Date])' />
      </column>
      <column caption='Hour of Day' datatype='integer' name='[Calculation_5712874514640898]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [Order Date])' />
      </column>
      <column caption='City' datatype='string' name='[Calculation_5712874514780163]' role='dimension' semantic-role='[City].[Name]' type='nominal'>
        <calculation class='tableau' formula='TRIM(SPLIT([Purchase Address], &apos;,&apos;, 2))' />
      </column>
      <column caption='State' datatype='string' name='[Calculation_5712874514837508]' role='dimension' semantic-role='[State].[Name]' type='nominal'>
        <calculation class='tableau' formula='TRIM(LEFT(TRIM(SPLIT([Purchase Address], &apos;,&apos;, 3)), 2))' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_5712874514894853]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_5712874514472960]) / COUNTD([Order ID])' />
      </column>
      <column caption='Product Rank' datatype='integer' name='[Calculation_5712874517057544]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(SUM([Calculation_5712874514472960]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Show Top N Products' datatype='boolean' name='[Calculation_5712874517159945]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_5712874517057544] &lt;= [Parameters].[Parameter 5712874516615174]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Sales Contribution %' datatype='real' name='[Calculation_5712874517241866]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_5712874514472960]) / TOTAL(SUM([Calculation_5712874514472960]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Average Selling Price' datatype='real' name='[Calculation_5712874517393419]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_5712874514472960]) / SUM([Quantity Ordered])' />
      </column>
      <column caption='City-State' datatype='string' name='[Calculation_5712874518700044]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_5712874514780163] + &quot;, &quot; + [Calculation_5712874514837508]' />
      </column>
      <column caption='Product Quantity Rank' datatype='integer' name='[Calculation_5712874537443341]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(SUM([Quantity Ordered]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Show Top N Products by Quantity' datatype='boolean' name='[Calculation_5712874537517070]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_5712874537443341] &lt;= [Parameters].[Parameter 5712874516615174]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
